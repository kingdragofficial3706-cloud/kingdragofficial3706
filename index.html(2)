<!-- Scripts for calculations & interactive plotting -->
<script>
    // Scenario Parameters (representing Malaysia MR219 Rice growth curves based on experimental crop cycles)
    const scenarios = {
        standard: {
            K: 1200,   // Maximum cumulative dry matter carrying capacity (g/m^2)
            a: 150,    // Initial scale parameter
            r: 0.07,   // Base continuous growth coefficient 
            title: "Standard Treatment (MARDI)",
            btnId: "btn-standard"
        },
        low: {
            K: 800,    // Lower dry biomass ceiling (e.g. soil nutrient lock / weed pressure)
            a: 120,
            r: 0.058,  // Slower crop growth rate coefficient
            title: "Sub-Optimal (Low Nitrogen)",
            btnId: "btn-low"
        },
        high: {
            K: 1550,   // Highest possible dry matter saturation (Precision farming techniques)
            a: 180,
            r: 0.082,  // Rapid nitrogen conversion coefficient
            title: "Smart Precision Agriculture",
            btnId: "btn-high"
        }
    };

    let activeScenario = 'standard';
    let chartInstance = null;

    // Biomass Function f(t) calculation
    function calculateF(t, param) {
        const { K, a, r } = param;
        return K / (1 + a * Math.exp(-r * t));
    }

    // Derivative Function f'(t) calculation
    function calculateFPrime(t, param) {
        const { K, a, r } = param;
        const expTerm = Math.exp(-r * t);
        const denominator = Math.pow(1 + a * expTerm, 2);
        return (K * a * r * expTerm) / denominator;
    }

    // Generate data arrays for Chart.js
    function generateChartData(param) {
        const labels = [];
        const dataF = [];
        const dataFPrime = [];

        for (let t = 0; t <= 120; t++) {
            labels.push(t);
            dataF.push(calculateF(t, param).toFixed(1));
            dataFPrime.push(calculateFPrime(t, param).toFixed(2));
        }

        return { labels, dataF, dataFPrime };
    }

    // STREAMING_CHUNK: Instantiating and configuring Chart.js details...
