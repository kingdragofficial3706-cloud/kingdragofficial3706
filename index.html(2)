    // STREAMING_CHUNK: Biological analysis engine...
    // Formulate agricultural recommendations based on day index
    function getBiologicalAnalysis(day, fVal, fPrimeVal) {
        let title = "";
        let description = "";
        let agriculturalRecommendation = "";

        if (day <= 15) {
            title = "Lag Phase: Seedling Establishment";
            description = `The rice plant is forming seedling radicles and early root clusters in the soil. Cumulative biomass f(t) is extremely low (${fVal} g/m²). The growth derivative is hovering near zero (${fPrimeVal} g/m²/day).`;
            agriculturalRecommendation = "The field should maintain minimum moisture levels (shallow saturated layer 1-2cm). Fertilization needs are low at this juncture as the plant consumes its internal seed endosperm storage.";
        } else if (day <= 45) {
            title = "Exponential Phase: Active Tillering";
            description = `Active vegetative expansion has started! The growth derivative f'(t) is accelerating, climbing to ${fPrimeVal} g/m²/day. Multiple secondary stems (tillers) are branching out.`;
            agriculturalRecommendation = "The first major nitrogen application window (top dressing) begins. High derivative values highlight that the crop is highly responsive to immediate soil nutrient changes, speeding up root uptake.";
        } else if (day <= 75) {
            title = "Peak Acceleration: Panicle Initiation";
            description = `The S-Curve reaches its maximum slope (the mathematical inflection point). The instantaneous rate of growth f'(t) is at its maximum of ${fPrimeVal} g/m²/day. The crop is forming internal reproductive panicles.`;
            agriculturalRecommendation = "Critical top-dressing fertilizer window (specifically Urea/NPK mixture). Missing this timing severely limits seed headcount per panicle. Soil must remain continuously inundated to avoid drought stress.";
        } else if (day <= 100) {
            title = "Decelerating Phase: Flowering & Grain Filling";
            description = `Cumulative weight f(t) continues to increase to ${fVal} g/m², but growth velocity f'(t) has dropped to ${fPrimeVal} g/m²/day. Biological energy shifts entirely from stem expansion to starch accumulation in the grains.`;
            agriculturalRecommendation = "The derivative decreases as the plant structure hardens. Avoid applying excess vegetative nitrogen now, as it will only promote leaf pathogens rather than improving harvest yield indices.";
        } else {
            title = "Stationary / Ripening Phase: Pre-Harvest";
            description = `The accumulation S-curve has flatlined completely. The dry weight derivative f'(t) drops to ${fPrimeVal} g/m²/day. The rice grains are ripening and moisture content is dropping.`;
            agriculturalRecommendation = "Biochemical biomass accumulation has reached its ceiling. The paddy fields must be completely drained 10-14 days before harvest to solidify the soil and allow heavy machinery access.";
        }

        return { title, description, agriculturalRecommendation };
    }

    // STREAMING_CHUNK: Synchronizing the GUI components...
    // Update dashboard elements based on active Day
    function updateActiveCalculation(day) {
        const param = scenarios[activeScenario];
        const fVal = calculateF(day, param).toFixed(1);
        const fPrimeVal = calculateFPrime(day, param).toFixed(2);

        // Update DOM
        document.getElementById('slider-day-val').textContent = day;
        document.getElementById('target-day').textContent = day;
        document.getElementById('stat-f').textContent = fVal;
        document.getElementById('stat-fprime').textContent = fPrimeVal;

        // Update Dynamic Explanatory Text
        const analysis = getBiologicalAnalysis(day, fVal, fPrimeVal);
        document.getElementById('stat-phase-title').textContent = analysis.title;
        document.getElementById('stat-phase-desc').textContent = analysis.description;
        document.getElementById('stat-agronomic-desc').textContent = analysis.agriculturalRecommendation;

        // Highlight corresponding points on Chart.js (without re-rendering full dataset structure)
        if (chartInstance) {
            chartInstance.setActiveElements([
                { datasetIndex: 0, index: day },
                { datasetIndex: 1, index: day }
            ]);
            chartInstance.tooltip.setActiveElements([
                { datasetIndex: 0, index: day },
                { datasetIndex: 1, index: day }
            ]);
            chartInstance.update();
        }
    }

    // Handle scenario switches (Standard vs Suboptimal vs Smart Precision Farming)
    function changeScenario(key) {
        activeScenario = key;
        const param = scenarios[key];

        // Highlight Active Button in CSS classes
        Object.keys(scenarios).forEach(k => {
            const btn = document.getElementById(scenarios[k].btnId);
            const indicatorSpan = btn.querySelector('span:last-child');
            if (k === key) {
                btn.className = "w-full text-left p-3 rounded-xl border border-emerald-500/30 bg-emerald-950/20 hover:bg-emerald-950/30 transition duration-150 flex justify-between items-center group";
                indicatorSpan.className = "text-emerald-400 text-xs font-semibold bg-emerald-900/50 px-2 py-1 rounded";
                indicatorSpan.textContent = "Active";
            } else {
                btn.className = "w-full text-left p-3 rounded-xl border border-slate-800 bg-slate-900/50 hover:bg-slate-800/50 transition duration-150 flex justify-between items-center";
                indicatorSpan.className = "text-slate-500 text-xs font-semibold bg-slate-950 px-2 py-1 rounded";
                indicatorSpan.textContent = "Draft";
            }
        });

        // Update Mathematical Parameters display in Math Box
        document.getElementById('param-K').textContent = param.K;
        document.getElementById('param-a').textContent = param.a;
        document.getElementById('param-r').textContent = param.r;

        // Regene data & redraw charts
        const dataPack = generateChartData(param);
        chartInstance.data.datasets[0].data = dataPack.dataF;
        chartInstance.data.datasets[1].data = dataPack.dataFPrime;
        chartInstance.update();

        // Refresh current calculation details using the newly selected parameters
        const currentDay = parseInt(document.getElementById('daySlider').value);
        updateActiveCalculation(currentDay);
    }

    // Initialize App on Window Load
    window.onload = function() {
        initChart();
        
        // Connect Slider Input listener
        const slider = document.getElementById('daySlider');
        slider.addEventListener('input', function() {
            updateActiveCalculation(parseInt(this.value));
        });

        // Execute initial calibration run
        updateActiveCalculation(60);
    }
</script>
