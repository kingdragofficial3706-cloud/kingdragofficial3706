    function initChart() {
        const ctx = document.getElementById('growthChart').getContext('2d');
        const dataPack = generateChartData(scenarios[activeScenario]);

        chartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: dataPack.labels,
                datasets: [
                    {
                        label: 'Cumulative Dry Matter f(t) (g/m²)',
                        data: dataPack.dataF,
                        borderColor: '#10b981', // Emerald 500
                        backgroundColor: 'rgba(16, 185, 129, 0.05)',
                        borderWidth: 3.5,
                        yAxisID: 'yCumulative',
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        tension: 0.1,
